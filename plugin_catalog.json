    "ApiConnection.Teams_PostCard":    { "pretty_category": "Microsoft Teams",     "pretty_type": "Post card in a chat or channel" }
  },
  "hints": [
    {
      "type": "ApiConnection",
      "subtype": "ApiConnection.Email_V2_SendShared",
      "enabled": true,
      "ways_to_match": [
        {
          "name": "office365_base",
          "needs_all": true,
          "conditions": [
            { "field": "inputs.host.connection.name", "op": "contains", "value": "['office365']" },
            { "field": "inputs.method",               "op": "equals",   "value": "post" },
            { "field": "inputs.path",                 "op": "contains", "value": "/v2/SharedMailbox/Mail" }
          ]
        },
        {
          "name": "office365_conn_1",
          "needs_all": true,
          "conditions": [
            { "field": "inputs.host.connection.name", "op": "contains",   "value": "['office365-1']" },
            { "field": "inputs.method",               "op": "equals",   "value": "post" },
            { "field": "inputs.path",                   "op": "contains", "value": "/v2/SharedMailbox/Mail" }
          ]
        },
              {
          "name": "office365_conn_2",
          "needs_all": true,
          "conditions": [
            { "field": "inputs.body.MailboxAddress",   "op": "exists",   "value": "true" },
            { "field": "inputs.path",                  "op": "contains", "value": "/v2/SharedMailbox/Mail" }
          ]
        }
      ]
    },
    {
